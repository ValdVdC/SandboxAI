# ═══════════════════════════════════════════════════════════════════════════
# 🔐 SandboxAI — Variáveis de Ambiente (.env.example)
# ═══════════════════════════════════════════════════════════════════════════
# 
# IMPORTANTE: Nunca commite o arquivo .env no repositório.
# Este arquivo (.env.example) deve sempre estar atualizado, mas SEM valores reais.
#
# Para usar: 
#   cp .env.example .env
#   # Edite .env com suas configurações reais
#
# ═══════════════════════════════════════════════════════════════════════════

# ─── DOCKER COMPOSE ────────────────────────────────────────────────────────
# Mantém nomes de recursos estáveis (containers, networks, volumes)
# entre sessões/terminais. Evita criar conjuntos paralelos de volumes.
COMPOSE_PROJECT_NAME=sandboxai

# ─── BANCO DE DADOS ────────────────────────────────────────────────────────
# PostgreSQL 15 — Banco relacional principal
# ───────────────────────────────────────────────────────────────────────────

POSTGRES_USER=sandboxai
POSTGRES_PASSWORD=change-me-in-production
POSTGRES_DB=sandboxai

DATABASE_URL=postgresql://sandboxai:change-me-in-production@postgres:5432/sandboxai

# ─── FILA DE MENSAGENS ────────────────────────────────────────────────────
# Redis 7 — Fila para execução assíncrona de testes
# ───────────────────────────────────────────────────────────────────────────

REDIS_URL=redis://redis:6379

# ─── API (FastAPI) ────────────────────────────────────────────────────────
# Configurações do servidor FastAPI
# ───────────────────────────────────────────────────────────────────────────

# Chave secreta para assinar tokens JWT
# Gere uma chave forte em produção, por exemplo:
#   python -c "import secrets; print(secrets.token_urlsafe(32))"
JWT_SECRET=change-me-in-production-with-strong-secret

# Tempo de expiração do token JWT em horas
JWT_EXPIRE_HOURS=24

# Modo debug (desabilitar em produção)
DEBUG=false

# Origens CORS permitidas (em dev: *, em prod: domínios específicos)
ALLOWED_ORIGINS=*

# ─── WORKERS (Celery) ────────────────────────────────────────────────────
# Configurações dos executores de testes
# ────────────────────────────────────────────────────────────────────────

# Timeout máximo por container em segundos
MAX_CONTAINER_TIMEOUT=60

# Número máximo de testes simultâneos
MAX_CONCURRENT_TESTS=10

# ─── PROVIDERS DE LLM ──────────────────────────────────────────────────────
# Chaves de API para os diferentes provedores de LLM
# Ao menos um provider deve estar configurado
# ───────────────────────────────────────────────────────────────────────────

# OLLAMA (Local, sem custo — recomendado para desenvolvimento)
# URL do servidor Ollama rodando localmente
OLLAMA_URL=http://ollama:11434

# GROQ (Gratuito com conta — recomendado para testes)
# Obtenha em: https://console.groq.com
GROQ_API_KEY=

# OpenAI (Pago — para produção)
# Obtenha em: https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Anthropic (Pago — para produção)
# Obtenha em: https://console.anthropic.com/api-keys
ANTHROPIC_API_KEY=

# ─── FRONTEND (React + Vite) ──────────────────────────────────────────────
# Configurações do cliente React
# ───────────────────────────────────────────────────────────────────────────

# URL da API backend (deve ser acessível do navegador)
VITE_API_URL=http://localhost:8000

# ═══════════════════════════════════════════════════════════════════════════
# 📝 NOTAS E DICAS
# ═══════════════════════════════════════════════════════════════════════════
#
# 1. DESENVOLVIMENTO LOCAL:
#    - Use Ollama (local, sem custo) para testar sem gastar
#    - Ou use Groq (gratuito) com conta
#
# 2. JWT_SECRET EM PRODUÇÃO:
#    Gere uma chave criptográfica forte:
#      python -c "import secrets; print(secrets.token_urlsafe(32))"
#
# 3. POSTGRES_PASSWORD EM PRODUÇÃO:
#    Use uma senha forte (mínimo 16 caracteres, mix de caracteres especiais)
#
# 4. VERIFICANDO A CONFIGURAÇÃO:
#    docker compose up -d
#    docker compose logs -f api
#    curl http://localhost:8000/health
#
# 5. TROUBLESHOOTING:
#    - Se a API não conecta no Postgres: aguarde a inicialização
#    - Se o Worker não inicia: verifique REDIS_URL
#    - Se o Frontend não conecta na API: verifique VITE_API_URL
#
# ═══════════════════════════════════════════════════════════════════════════
